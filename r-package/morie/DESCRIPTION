Package: morie
Type: Package
Title: Multi-Domain Open Research and Inferential Estimation
Version: 0.8.0
Authors@R: c(
  person(
    given = "Vansh Singh",
    family = "Ruhela",
    email = "hadesllm@proton.me",
    role = c("aut", "cre"),
    comment = c(ORCID = "0009-0004-1750-3592")
