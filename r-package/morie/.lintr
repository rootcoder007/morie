linters: linters_with_defaults(
    line_length_linter = line_length_linter(120L),
    object_name_linter = NULL,
    commented_code_linter = NULL,
    object_length_linter = object_length_linter(length = 50L),
    indentation_linter = NULL,
    object_usage_linter = NULL,
    brace_linter = NULL,
    commas_linter = NULL
  )
exclusions: list(
    "data-raw" = Inf,
    "tests/testthat" = list(
      undesirable_function_linter = Inf,
      library_call_linter = Inf
    ),
    "vignettes" = list(
      library_call_linter = Inf,
      line_length_linter = Inf
    ),
    "R/RcppExports.R" = Inf,
    "R/dataset_catalog.R" = list(line_length_linter = Inf),
    "R/study_core.R" = list(line_length_linter = Inf),
    "R/study_reporting.R" = list(line_length_linter = Inf),
    "R/rndsr.R" = list(line_length_linter = Inf),
    "R/rfens.R" = list(line_length_linter = Inf)
  )
encoding: "UTF-8"
