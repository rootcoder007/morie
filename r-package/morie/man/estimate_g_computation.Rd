\name{estimate_g_computation}
\alias{estimate_g_computation}
\title{G-computation (outcome regression) ATE estimator}
\description{
  G-computation (outcome regression) ATE estimator

Estimates the ATE by:
\deqn{\widehat{ATE} = \frac{1}{n}\sum_i \bigl[\hat{\mu}_1(X_i) - \hat{\mu}_0(X_i)\bigr]}
}
\value{
  Named list: 'ate', 'se', 'ci_lower', 'ci_upper'.
}
\examples{
set.seed(2026)
n <- 200L
x <- rnorm(n)
D <- rbinom(n, 1, plogis(0.5 * x))
y <- 0.7 * D + 0.3 * x + rnorm(n)
df <- data.frame(D = D, y = y, age = x)
res <- estimate_g_computation(df, treatment = "D",
                             outcome = "y",
                             covariates = "age")
res$ate
}
