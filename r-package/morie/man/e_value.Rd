}
\arguments{
\item{rr}{Risk ratio estimate (> 0). Supply > 1; if < 1, pass its reciprocal.}
\item{rr_lower}{Lower bound of the 95\% CI (used to compute E-value for CI).}
}
\value{
Named list with components \code{e_value} and \code{e_value_ci}.
}
