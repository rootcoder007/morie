\name{substance_categories}
\alias{substance_categories}
\docType{data}
\title{Substance category lookup table}
\description{
  Mapping from raw substance / drug-class strings (as they appear in
  the source datasets) to the canonical category labels used in
  \pkg{morie} analyses.
}
\usage{
  data(substance_categories)
}
\format{
  A data frame with two columns: \code{raw} (the source string) and
  \code{category} (the canonical label).
}
\keyword{datasets}
