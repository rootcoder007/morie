    given-names: "Vansh Singh"
    orcid: "https://orcid.org/0009-0004-1750-3592"
    name-particle: "Singh"
    # morie pronunciation: /ˈmɔɪraɪ/ -- "MOY-rye", like the Greek Moirai (the Fates)
    # IPA: /ʋənʃ sɪŋ ɾʊˈɦeːlɑː/
